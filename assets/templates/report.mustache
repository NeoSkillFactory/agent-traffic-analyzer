<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Agent Traffic Analysis Report</title>
  <style>
    body { font-family: Helvetica, Arial, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
    h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
    h2 { color: #34495e; margin-top: 30px; }
    table { border-collapse: collapse; width: 100%; margin: 15px 0; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background-color: #3498db; color: white; }
    tr:nth-child(even) { background-color: #f2f2f2; }
    .severity-critical { color: #e74c3c; font-weight: bold; }
    .severity-warning { color: #f39c12; font-weight: bold; }
    .severity-info { color: #3498db; }
    .metric { font-family: monospace; background: #f8f9fa; padding: 2px 6px; border-radius: 3px; }
    .suggestion { background: #eafaf1; border-left: 4px solid #27ae60; padding: 10px; margin: 10px 0; }
  </style>
</head>
<body>
  <h1>Agent Traffic Analysis Report</h1>

  <h2>Summary</h2>
  <table>
    <tr><th>Metric</th><th>Value</th></tr>
    <tr><td>Total Agents</td><td class="metric">{{total_agents}}</td></tr>
    <tr><td>Total Messages</td><td class="metric">{{total_messages}}</td></tr>
    <tr><td>Total Data Transferred</td><td class="metric">{{total_bytes}} bytes</td></tr>
    <tr><td>Failed Messages</td><td class="metric">{{failed_messages}} ({{failure_rate}}%)</td></tr>
    <tr><td>Average Latency</td><td class="metric">{{avg_latency_ms}} ms</td></tr>
    <tr><td>Unique Communication Channels</td><td class="metric">{{unique_edges}}</td></tr>
  </table>

  <h2>Bottlenecks</h2>
  {{#bottlenecks}}
  <div class="severity-{{severity}}">
    [{{severity}}] {{detail}}
  </div>
  {{/bottlenecks}}
  {{^bottlenecks}}
  <p>No bottlenecks detected.</p>
  {{/bottlenecks}}

  <h2>Optimization Suggestions</h2>
  {{#optimizations}}
  <div class="suggestion">
    <strong>[{{priority}}] {{strategy}}</strong><br>
    {{description}}
  </div>
  {{/optimizations}}

  <footer>
    <p><em>Generated by agent-traffic-analyzer</em></p>
  </footer>
</body>
</html>
